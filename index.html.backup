        <div class="info-box" style="margin-top: 30px;">
            <h3>COLUMNAS ANALIZADAS DE LA BASE DE DATOS:</h3>
            <p><strong>"Hora Salida Pabellón":</strong> Hora exacta en que el paciente TERMINA y SALE del pabellón quirúrgico (fin de la operación actual)</p>
            <p><strong>"Hora de inicio":</strong> Hora exacta en que la SIGUIENTE operación COMIENZA en ese mismo pabellón</p>
            <p><strong>La diferencia entre ambas horas</strong> nos indica cuánto tiempo pasó entre operaciones consecutivas en el mismo pabellón</p>
            <hr style="margin: 15px 0; border: 1px solid #ccc;">
            <p><strong>Importante:</strong> Solo se analizan operaciones <strong>CONSECUTIVAS</strong> del <strong>MISMO PABELLÓN</strong> en la <strong>MISMA FECHA</strong></p>
            <p style="font-size: 0.95em; margin-top: 10px;">No se comparan operaciones de diferentes pabellones ni de diferentes días.</p>
        </div>
    </div>

    <script>
        function openTab(tabName) {
            // Ocultar todos los contenidos
            var contents = document.getElementsByClassName('tab-content');
            for (var i = 0; i < contents.length; i++) {
                contents[i].classList.remove('active');
            }
            
            // Desactivar todos los tabs
            var tabs = document.getElementsByClassName('tab');
            for (var i = 0; i < tabs.length; i++) {
                tabs[i].classList.remove('active');
            }
            
            // Mostrar el contenido seleccionado
            document.getElementById(tabName).classList.add('active');
            event.target.classList.add('active');
        }

        function mostrarVerificacion(fecha, pabellon, horaFin, horaInicio, nombreHoja) {
            var mensaje = '=== INSTRUCCIONES PARA VERIFICAR ===\n\n';
            mensaje += 'Se abrirá el archivo Excel en la hoja "' + nombreHoja + '"\n\n';
            mensaje += 'BUSCA ESTE CASO:\n';
            mensaje += '   • FECHA: ' + fecha + '\n';
            mensaje += '   • PABELLÓN: ' + pabellon + '\n';
            mensaje += '   • Hora Fin Actual: ' + horaFin + '\n';
            mensaje += '   • Hora Inicio Siguiente: ' + horaInicio + '\n\n';
            mensaje += 'El Excel se abrirá directamente en la pestaña correcta.\n\n';
            mensaje += '¿Abrir el archivo Excel ahora?';
            
            if (confirm(mensaje)) {
                // Abrir el archivo de casos con la hoja específica
                var link = document.createElement('a');
                link.href = 'Casos tiempo de espera 2024.xlsx#' + nombreHoja.replace(/ /g, '%20');
                link.target = '_blank';
                link.click();
            }
        }
    </script>
